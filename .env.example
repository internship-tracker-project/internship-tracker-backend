# Copy this file to .env and fill in your own values
# Windows PowerShell: Copy-Item .env.example .env
# macOS/Linux: cp .env.example .env

DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Use a long, random secret for JWT signing (at least 32 bytes / high entropy).
# Example: openssl rand -base64 32
JWT_SECRET="your-strong-jwt-secret-here"

# Adzuna developer credentials (https://developer.adzuna.com/).
# Free tier: 1000 calls/month. Used by the job ingestion adapter.
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_APP_KEY="your-adzuna-app-key"

# Shared secret gating POST /jobs/ingest. Any long random string.
# Example: openssl rand -base64 32
INGEST_TOKEN="your-ingest-token-here"
